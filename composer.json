{
    "name": "nhnid128/doge-sweeper",
    "description": "Sweep Dogecoin wallets from WIF keys and send to a single address",
    "type": "application",
    "license": "MIT",
    "authors": [
        {
            "name": "nhnid128",
            "email": "contact@example.com"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "DogeSweeper\\": "src/"
        }
    },
    "scripts": {
        "start": "php bin/doge-sweeper",
        "lint": "phpstan analyse src/",
        "style": "phpcs --standard=PSR12 src/"
    },
    "bin": [
        "bin/doge-sweeper"
    ]
}
